# Copy relevant values into the repo-root .env (the backend reads from there,
# then from backend/.env). Do not commit real secrets.

# ── Required ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# First admin, created automatically on first startup.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong

# Signing key for session cookies. REQUIRED in production.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── Environment ──────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
DEBUG=false

# ── Database ─────────────────────────────────────────────────────────
# Set in production → Azure SQL Database. Unset → local SQLite (dev/tests only).
# IMPORTANT: create the Azure SQL Database with a UTF-8 collation so Hindi +
# emoji store correctly — e.g. collation  Latin1_General_100_CI_AS_SC_UTF8.
# Requires the "ODBC Driver 18 for SQL Server" installed on the host.
# DATABASE_URL=mssql+aioodbc://USER:PASSWORD@SERVER.database.windows.net:1433/DBNAME?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no

# ── Cookies / HTTPS ──────────────────────────────────────────────────
COOKIE_SECURE=0                  # set to 1 when served over HTTPS

# ── Models (override defaults if desired) ────────────────────────────
# MODEL_CONVERSATION=claude-sonnet-5
# MODEL_SCORING=claude-haiku-4-5
# MODEL_ASSESSMENT=claude-sonnet-5     # set to claude-opus-4-8 for higher-quality assessments

# ── Azure AI Speech (optional) ───────────────────────────────────────
# Set both to enable cloud STT + neural TTS + pronunciation assessment.
# Leave unset to use the browser Web Speech API fallback.
# AZURE_SPEECH_KEY=your-azure-speech-key
# AZURE_SPEECH_REGION=centralindia
